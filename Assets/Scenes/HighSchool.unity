  m_Script: {fileID: 11500000, guid: 97addb960f86ae24a96195f737d2adae, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  defaultPortrait: {fileID: 0}
  richLines: []
  lines:
  - You're.. What's your name again?
  - I'm Eugene...
  - Right! Eugene! The smart guy! Yeah!
  - You're exactly who I was looking for!
  - You were looking for me? Why?
  - Don't you know? It's hip to be square.
  - Look... I need your help, Eugene!
  - I lost my ring, it's a gold ring with a huge diamond!
  - Can you find it for me, pretty please?
  - I'll reward you! *wink*
  linesWhenActive:
  - I know you can find my ring, Eugene.
  - Maybe I'll reward you with a kiss?
  linesWhenCompleted: []
  linesWhenReadyToTurn:
  - You found it? Hand it over!
  linesAfterCompletion:
  - Thanks, Chad will be happy I didn't lose the ring he gave me. Get lost Nerd.
